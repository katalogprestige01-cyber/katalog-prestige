---
// Okruszki + BreadcrumbList schema (§2/§5). items: [{name, href}] — ostatni bez href.
import { absUrl } from '../data/site.mjs';
interface Crumb { name: string; href?: string; }
const { items } = Astro.props as { items: Crumb[] };
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.name,
    ...(c.href ? { item: absUrl(c.href) } : {}),
  })),
};
---
<nav class="crumbs wrap" aria-label="Okruszki">
  {items.map((c, i) => (
    <>
      {c.href ? <a href={c.href}>{c.name}</a> : <span>{c.name}</span>}
      {i < items.length - 1 ? <span> › </span> : null}
    </>
  ))}
</nav>
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
