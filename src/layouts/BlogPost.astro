---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { author as defaultAuthor } from '../data/author';
import { getCategory } from '../data/categories';
import { absUrl, SITE_NAME } from '../data/site.mjs';

const { entry } = Astro.props;
const d = entry.data;
const cat = getCategory(d.category);
const path = `/blog/${d.category}/${entry.slug}/`;
const heroImg = d.image ?? `/img/kat-${d.category}.jpg`;

const crumbs = [
  { name: 'Home', href: '/' },
  { name: 'Blog', href: '/blog/' },
  { name: cat?.title ?? d.category, href: `/blog/${d.category}/` },
  { name: d.title },
];

// Schema artykułu (§5). Wydawca + język + obrazek = pełniejsze rich results i lepsze parsowanie przez AI.
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: d.title,
  description: d.description,
  datePublished: d.pubDate.toISOString(),
  dateModified: (d.updatedDate ?? d.pubDate).toISOString(),
  inLanguage: 'pl-PL',
  image: absUrl(heroImg),
  author: { '@type': 'Person', name: defaultAuthor.name, jobTitle: defaultAuthor.role },
  publisher: {
    '@type': 'Organization',
    name: SITE_NAME,
    logo: { '@type': 'ImageObject', url: absUrl('/favicon.png') },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': absUrl(path) },
};

// Okruszki nawigacji jako dane strukturalne — to samo, co widać wizualnie, ale czytelne dla Google.
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: crumbs.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.name,
    item: absUrl(c.href ?? path),
  })),
};

const fmt = (dt) => new Intl.DateTimeFormat('pl-PL', { dateStyle: 'long' }).format(dt);
---
<BaseLayout title={d.title} description={d.description} path={path}
  image={d.image} ogType="article" jsonLd={[articleSchema, breadcrumbSchema]}>
  <section class="article-hero">
    <div class="bg" style={`background-image:url('${heroImg}')`}></div>
    <div class="scrim"></div>
  </section>
  <Breadcrumbs items={crumbs} />
  <article class="wrap section" style="padding-top:20px">
    <p class="eyebrow">{cat?.title ?? d.category}</p>
    <h1>{d.title}</h1>
    <p class="muted" style="text-transform:uppercase;letter-spacing:.08em;font-size:.82rem">
      {fmt(d.pubDate)}{d.updatedDate ? ` · akt. ${fmt(d.updatedDate)}` : ''} · {defaultAuthor.name}
    </p>
    <div class="prose">
      <slot />
    </div>
    <hr style="margin:40px 0;border:none;border-top:1px solid var(--line)" />
    <p class="muted"><strong>{defaultAuthor.name}</strong> — {defaultAuthor.bioShort} <a href="/o-nas/">Więcej o autorze →</a></p>
    {cat ? <p style="margin-top:16px"><a class="tag" href={`/blog/${cat.slug}/`}>← Wróć do: {cat.navLabel}</a></p> : null}
  </article>
</BaseLayout>
