---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';
import { activeCategories, getCategory } from '../../data/categories';

const posts = (await getCollection('blog', ({ data }) => data.draft !== true))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const crumbs = [{ name: 'Home', href: '/' }, { name: 'Blog' }];
---
<BaseLayout title="Blog — poradniki o wykończeniu wnętrz premium | Katalog Prestige"
  description="Poradniki, porównania i inspiracje o materiałach wykończeniowych premium: płytki, podłogi, kamień naturalny, armatura i ceramika."
  path="/blog/">
  <Breadcrumbs items={crumbs} />
  <section class="section wrap">
    <p class="eyebrow">Blog</p>
    <h1>Poradniki i inspiracje</h1>
    <p class="lead">Wszystko o materiałach wykończeniowych klasy premium — od wyboru po pielęgnację.</p>

    <div style="margin:24px 0;display:flex;gap:10px;flex-wrap:wrap">
      {activeCategories.map((c) => <a class="tag" href={`/blog/${c.slug}/`}>{c.navLabel}</a>)}
    </div>

    {posts.length === 0 ? (
      <div class="empty">Pierwsze wpisy pojawią się wkrótce. Zbieramy je w kategoriach powyżej.</div>
    ) : (
      <div class="grid">
        {posts.map((p) => (
          <a class="card" href={`/blog/${p.data.category}/${p.slug}/`} style="text-decoration:none;color:inherit">
            <span class="tag">{getCategory(p.data.category)?.navLabel}</span>
            <h3>{p.data.title}</h3>
            <p class="muted">{p.data.description}</p>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
