---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { author } from '../data/author';
const crumbs = [{ name: 'Home', href: '/' }, { name: 'Kontakt' }];
---
<BaseLayout title="Kontakt | Katalog Prestige"
  description="Skontaktuj się z redakcją Katalogu Prestige — pytania, współpraca, sugestie tematów o wykończeniu wnętrz premium."
  path="/kontakt/">
  <Breadcrumbs items={crumbs} />
  <section class="section wrap prose">
    <p class="eyebrow">Kontakt</p>
    <h1>Kontakt</h1>
    <p class="lead">Masz pytanie lub propozycję współpracy? Napisz.</p>
    <p>E-mail: <a href={`mailto:${author.email}`}>{author.email}</a></p>
    <div class="empty">Szablon — podmień adres e-mail i ewentualnie dodaj formularz kontaktowy.</div>
  </section>
</BaseLayout>
